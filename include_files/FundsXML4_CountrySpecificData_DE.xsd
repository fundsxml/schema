            <xs:complexType>
               <xs:sequence>
                  <xs:element name="Existing_Capital_Preservation" type="YesNoType">
                     <xs:annotation>
                        <xs:documentation xml:lang="en">06040-Identifies if a capital preservation method is used (Y) or not (N).</xs:documentation>
                        <xs:documentation xml:lang="de">06040-Identifiziert, ob eine Kapitalerhaltungsmethode verwendet wird (Y) oder nicht (N).</xs:documentation>
                        <xs:documentation xml:lang="fr">06040-Identifie si une méthode de préservation du capital est utilisée (Y) ou non (N).</xs:documentation>
                        <xs:documentation xml:lang="nl">06040-Geeft aan of een methode voor kapitaalbehoud wordt gebruikt (Y) of niet (N).</xs:documentation>
                        <xs:documentation xml:lang="es">06040-Identifica si se utiliza un método de preservación de capital (Y) o no (N).</xs:documentation>
                        <xs:documentation xml:lang="it">06040-Identifica se viene utilizzato un metodo di conservazione del capitale (Y) o meno (N).</xs:documentation>
