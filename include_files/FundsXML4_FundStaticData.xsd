<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:altova="http://www.altova.com/xml-schema-extensions"
           xmlns:vc="http://www.w3.org/2007/XMLSchema-versioning"
           xmlns:xs="http://www.w3.org/2001/XMLSchema"
           attributeFormDefault="unqualified"
           elementFormDefault="qualified"
           vc:minVersion="1.1">
   <xs:include schemaLocation="FundsXML4_Core.xsd"/>
   <xs:complexType name="BenchmarkProviderCompany">
      <xs:annotation>
         <xs:documentation>Benchmark index provider company with ESMA registration status (EU Benchmark Regulation)</xs:documentation>
         <xs:documentation xml:lang="en">Benchmark index provider company with ESMA registration status (EU Benchmark Regulation)</xs:documentation>
         <xs:documentation xml:lang="de">Benchmark Index Provider Company mit ESMA-Registrierungsstatus (EU Benchmark Regulation)</xs:documentation>
         <xs:documentation xml:lang="fr">Société provider de benchmark index avec statut d'enregistrement ESMA (EU Benchmark Regulation)</xs:documentation>
         <xs:documentation xml:lang="nl">Benchmark index provider bedrijf met ESMA-registratiestatus (EU Benchmark Regulation)</xs:documentation>
         <xs:documentation xml:lang="es">Empresa proveedora del benchmark index con estado de registro ESMA (EU Benchmark Regulation)</xs:documentation>
         <xs:documentation xml:lang="it">Società fornitrice di indici di riferimento con status di registrazione ESMA (regolamento sui benchmark dell'UE)</xs:documentation>
         <xs:documentation xml:lang="cs">Společnost poskytovatele benchmarkového indexu se statusem registrace ESMA (nařízení EU o benchmarcích)</xs:documentation>

         <xs:documentation xml:lang="hu">Benchmark index szolgáltató társaság ESMA regisztrációs státusszal (EU Benchmark Rendelet)</xs:documentation>
      </xs:annotation>
      <xs:complexContent>
         <xs:extension base="CompanyType">
            <xs:sequence>
               <xs:element minOccurs="0" name="IsESMARegisterd" type="xs:boolean">
                  <xs:annotation>
                     <xs:documentation>Whether the benchmark provider is ESMA registered under EU Benchmark Regulation</xs:documentation>
                     <xs:documentation xml:lang="en">Whether the benchmark provider is ESMA registered under EU Benchmark Regulation</xs:documentation>
                     <xs:documentation xml:lang="de">Ob der Benchmark-Provider unter der EU Benchmark-Verordnung bei ESMA registriert ist</xs:documentation>
                     <xs:documentation xml:lang="fr">Si le fournisseur de benchmark est enregistré auprès de l'ESMA en vertu du règlement européen sur les indices de référence</xs:documentation>
                     <xs:documentation xml:lang="nl">Of de benchmarkprovider ESMA-geregistreerd is onder de EU Benchmark-verordening</xs:documentation>
                     <xs:documentation xml:lang="es">Si el proveedor del benchmark está registrado en ESMA según el Reglamento europeo de índices de referencia</xs:documentation>
                     <xs:documentation xml:lang="it">Se il fornitore di benchmark è registrato presso l'ESMA ai sensi del regolamento europeo sui benchmark</xs:documentation>
                     <xs:documentation xml:lang="cs">Zda je poskytovatel benchmarku registrován u ESMA podle nařízení EU o benchmarcích</xs:documentation>
                     <xs:documentation xml:lang="hu">Hogy a benchmark szolgáltató ESMA-regisztrált-e az EU Benchmark Rendelet alapján</xs:documentation>
                  </xs:annotation>
               </xs:element>
            </xs:sequence>
         </xs:extension>
      </xs:complexContent>
   </xs:complexType>
   <xs:complexType name="BenchmarkStaticDataType">
      <xs:annotation>
         <xs:documentation>Static benchmark data including name, currency, provider and benchmark components for blended benchmarks</xs:documentation>
         <xs:documentation xml:lang="en">Static benchmark data including name, currency, provider and benchmark components for blended benchmarks</xs:documentation>
         <xs:documentation xml:lang="de">Statische Benchmark-Daten einschließlich Name, Währung, Provider und Benchmark Components für Blended Benchmarks</xs:documentation>
         <xs:documentation xml:lang="fr">Données statiques de benchmark incluant nom, devise, provider et benchmark components pour blended benchmarks</xs:documentation>
         <xs:documentation xml:lang="nl">Statische benchmark gegevens inclusief naam, valuta, provider en benchmark components voor blended benchmarks</xs:documentation>
         <xs:documentation xml:lang="es">Datos estaticos del benchmark incluyendo nombre, divisa, proveedor y componentes del benchmark para blended benchmarks</xs:documentation>
         <xs:documentation xml:lang="it">Dati di benchmark statici tra cui nome, valuta, fornitore e componenti di benchmark per benchmark misti</xs:documentation>
