						<xs:enumeration value="No hedge"/>
						<xs:enumeration value="Full NAV hedge"/>
						<xs:enumeration value="Full Portfolio hedge"/>
						<xs:enumeration value="Partial hedge"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
		</xs:sequence>
