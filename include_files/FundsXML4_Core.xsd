								<xs:documentation xml:lang="nl">Ander prijstype: inkoopprijs per aandeel</xs:documentation>
								<xs:documentation xml:lang="es">Otro tipo de precio de reembolso por acción</xs:documentation>
								<xs:documentation xml:lang="it">Altro tipo di prezzo Prezzo di rimborso per azione</xs:documentation>
								<xs:documentation xml:lang="cs">Jiný typ ceny: odkupní cena na akcii</xs:documentation>
