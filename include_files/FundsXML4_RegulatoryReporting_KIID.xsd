         <xs:element name="FundID">
            <xs:annotation>
               <xs:documentation xml:lang="en">Art.4-4 Fund or Share class(es) identification</xs:documentation>
               <xs:documentation xml:lang="de">Art. 4-4 Identifikation des Fonds oder der Anteilsklasse(n)</xs:documentation>
               <xs:documentation xml:lang="fr">Art.4-4 Fonds ou Classe d'actions(es) identification</xs:documentation>
               <xs:documentation xml:lang="nl">Art.4-4 Fonds van Aandelenklasse(es) identification</xs:documentation>
               <xs:documentation xml:lang="es">Art. 4-4 Identificación del fondo o clase(s) de participaciones</xs:documentation>
               <xs:documentation xml:lang="it">Art.4-4 Identificazione del fondo o della/e classe/i di azioni</xs:documentation>
               <xs:documentation xml:lang="cs">Čl. 4-4 Identifikace fondu nebo Share Class (tříd akcií)</xs:documentation>
               <xs:documentation xml:lang="hu">Art.4-4 Alap or Sorozat(es) identification</xs:documentation>
               <xs:documentation xml:lang="da">Art.4-4 Identifikation af fond eller Share class(es)</xs:documentation>
               <xs:documentation xml:lang="pl">Art.4-4 Identyfikacja funduszu lub Share class(es)</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element maxOccurs="unbounded" name="ShareClass">
                  	<xs:annotation>
                  	   <xs:documentation xml:lang="en">Share class data within the KIID identification section</xs:documentation>
                  	   <xs:documentation xml:lang="de">Anteilsklassendaten im KIID-Identifikationsabschnitt</xs:documentation>
                  	   <xs:documentation xml:lang="fr">Données de classe de parts dans la section d'identification KIID</xs:documentation>
                  	   <xs:documentation xml:lang="nl">Aandelenklassegegevens in de KIID-identificatiesectie</xs:documentation>
                  	   <xs:documentation xml:lang="es">Datos de clase de participación en la sección de identificación KIID</xs:documentation>
                  	   <xs:documentation xml:lang="it">Dati della classe di azioni nella sezione di identificazione KIID</xs:documentation>
                  	   <xs:documentation xml:lang="hu">Sorozat adatok a KIID azonosítási részben</xs:documentation>
                  	   <xs:documentation xml:lang="cs">Údaje o třídě akcií v identifikační sekci KIID</xs:documentation>
                  	   <xs:documentation xml:lang="da">Share Class-data i KIID-identifikationssektionen</xs:documentation>
                  	   <xs:documentation xml:lang="pl">Dane Share Class w sekcji identyfikacyjnej KIID</xs:documentation>
                  	</xs:annotation>
                     <xs:complexType>
                        <xs:sequence>
                           <xs:element name="ShareClassName" type="xs:string">
