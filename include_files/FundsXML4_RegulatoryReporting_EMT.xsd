					<xs:documentation xml:lang="fr">EMT Version 4 Report</xs:documentation>
					<xs:documentation xml:lang="nl">EMT Versie 4 Report</xs:documentation>
					<xs:documentation xml:lang="es">EMT Versión 4 Report</xs:documentation>
					<xs:documentation xml:lang="it">Report EMT Versione 4</xs:documentation>
					<xs:documentation xml:lang="cs">EMT Version 4 Report</xs:documentation>
					<xs:documentation xml:lang="hu">EMT Verzio 4 Jelentes</xs:documentation>
					<xs:documentation xml:lang="da">EMT Version 4 Report</xs:documentation>
				</xs:annotation>
