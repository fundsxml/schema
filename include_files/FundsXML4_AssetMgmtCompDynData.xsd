   <xs:complexType name="AssetManagementCompanyFundAssetsType">
      <xs:annotation>
         <xs:documentation xml:lang="en">Company assets data</xs:documentation>
         <xs:documentation xml:lang="de">Vermögensdaten des Unternehmens</xs:documentation>
         <xs:documentation xml:lang="fr">Company assets données</xs:documentation>
         <xs:documentation xml:lang="nl">Company assets gegevens</xs:documentation>
         <xs:documentation xml:lang="es">Company activos data</xs:documentation>
         <xs:documentation xml:lang="it">Dati del patrimonio aziendale</xs:documentation>
         <xs:documentation xml:lang="cs">Údaje o aktivech společnosti</xs:documentation>

         <xs:documentation xml:lang="hu">Vállalati eszközadatok</xs:documentation>
         <xs:documentation xml:lang="da">Data om selskabets aktiver</xs:documentation>
         <xs:documentation xml:lang="pl">Dane aktywów spółki</xs:documentation>
         <xs:documentation xml:lang="sv">Data om bolagets tillgångar</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="NetAssets" type="xs:decimal">
            <xs:annotation>
               <xs:documentation xml:lang="en">Net assets in total, calculated on an overall basis including outstanding debts, bank loans, and other liabilities (Net Asset Value approach). In thousands of currency</xs:documentation>
               <xs:documentation xml:lang="de">Nettovermögen insgesamt, berechnet auf Gesamtbasis einschließlich ausstehender Schulden, Bankdarlehen und anderer Verbindlichkeiten (NAV-Ansatz). In Tausend Währungseinheiten</xs:documentation>
               <xs:documentation xml:lang="fr">Net assets dans total, calculé on un overall basis y compris en cours debts, bank loans, et autre liabilities (Net Actif Valeur approach). In thousands de devise</xs:documentation>
               <xs:documentation xml:lang="nl">Netto assets in totaal, berekend on een overall basis inclusief uitstaand debts, bank loans, en overig liabilities (Netto Actief Waarde approach). In thousands van valuta</xs:documentation>
               <xs:documentation xml:lang="es">Activos netos totales, calculados sobre una base global que incluye las deudas pendientes, los préstamos bancarios y otros pasivos (enfoque Net Asset Value). En miles de la moneda</xs:documentation>
               <xs:documentation xml:lang="it">Patrimonio netto totale, calcolato su base complessiva compresi i debiti in essere, i prestiti bancari e altre passività (approccio del valore patrimoniale netto). In migliaia di valuta</xs:documentation>
               <xs:documentation xml:lang="cs">Čistá aktiva celkem, vypočtená na celkové bázi včetně nesplacených dluhů, bankovních úvěrů a dalších závazků (přístup Net Asset Value). V tisících měny</xs:documentation>

               <xs:documentation xml:lang="hu">Nettó eszközök összesen, teljes körű alapon számítva, beleértve a fennálló tartozásokat, banki hiteleket és egyéb kötelezettségeket (nettó eszközérték megközelítés). A deviza ezreseiben</xs:documentation>
               <xs:documentation xml:lang="da">Nettoaktiver i alt, beregnet på samlet basis inklusive udestående gæld, banklån og andre forpligtelser (Net Asset Value-tilgang). I tusinder af valuta</xs:documentation>
               <xs:documentation xml:lang="pl">Aktywa netto ogółem, obliczone na zasadzie całościowej z uwzględnieniem zaległych zobowiązań, kredytów bankowych i innych zobowiązań (podejście Net Asset Value). W tysiącach waluty</xs:documentation>
               <xs:documentation xml:lang="sv">Nettotillgångar totalt, beräknade på en övergripande basis inklusive utestående skulder, banklån och andra åtaganden (Net Asset Value-metod). I tusental av valutan</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="GrossAssets" type="xs:decimal">
            <xs:annotation>
               <xs:documentation xml:lang="en">Assets in total, calculated on a basis excluding outstanding debts, bank loans, and other liabilities (Gross Asset Value approach). In thousands of currency</xs:documentation>
               <xs:documentation xml:lang="de">Vermögen insgesamt, berechnet ohne ausstehende Schulden, Bankdarlehen und andere Verbindlichkeiten (Bruttovermögenswert-Ansatz). Aktivvermögen. In Tausend Währungseinheiten</xs:documentation>
               <xs:documentation xml:lang="fr">Assets dans total, calculé on un basis à l'exclusion de en cours debts, bank loans, et autre liabilities (Brut Actif Valeur approach). In thousands de devise</xs:documentation>
               <xs:documentation xml:lang="nl">Assets in totaal, berekend on een basis exclusief uitstaand debts, bank loans, en overig liabilities (Bruto Actief Waarde approach). In thousands van valuta</xs:documentation>
               <xs:documentation xml:lang="es">Activos totales, calculados sobre una base que excluye las deudas pendientes, los préstamos bancarios y otros pasivos (enfoque Gross Asset Value). En miles de la moneda</xs:documentation>
               <xs:documentation xml:lang="it">Attività in totale, calcolate escludendo debiti in essere, prestiti bancari e altre passività (approccio del valore patrimoniale lordo). In migliaia di valuta</xs:documentation>
               <xs:documentation xml:lang="cs">Aktiva celkem, vypočtená na základě bez zohlednění nesplacených dluhů, bankovních úvěrů a ostatních závazků (přístup Gross Asset Value). V tisících měnových jednotek</xs:documentation>

               <xs:documentation xml:lang="hu">Összes eszköz, a kintlévő tartozások, banki kölcsönök és egyéb kötelezettségek nélkül számítva (Gross Asset Value megközelítés). Ezer pénznemegységben</xs:documentation>
               <xs:documentation xml:lang="da">Aktiver i alt, beregnet på et grundlag eksklusive udestående gæld, banklån og andre forpligtelser (Gross Asset Value-tilgang). I tusinder af valuta</xs:documentation>
               <xs:documentation xml:lang="pl">Aktywa łącznie, obliczone na podstawie wykluczającej niespłacone zobowiązania, kredyty bankowe i inne pasywa (podejście Gross Asset Value). W tysiącach jednostek waluty</xs:documentation>
               <xs:documentation xml:lang="sv">Tillgångar totalt, beräknade på en basis exklusive utestående skulder, banklån och andra skulder (Gross Asset Value-metoden). I tusental av valutan</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="AssetManagementCompanySalesType">
      <xs:annotation>
         <xs:documentation xml:lang="en">Company sales data</xs:documentation>
         <xs:documentation xml:lang="de">Vertriebsdaten des Unternehmens</xs:documentation>
         <xs:documentation xml:lang="fr">Company sales données</xs:documentation>
         <xs:documentation xml:lang="nl">Company sales gegevens</xs:documentation>
         <xs:documentation xml:lang="es">Datos de ventas de la sociedad</xs:documentation>
