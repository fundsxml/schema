   <xs:complexType name="PRIIPS_DE_EPT_PiaType">
      <xs:annotation>
         <xs:documentation xml:lang="en">Germany-specific PRIIPs European Product Template (EPT) PIA extension containing product characteristics and target market data for German market requirements</xs:documentation>
         <xs:documentation xml:lang="de">Deutschland-spezifische PRIIPs European Product Template (EPT) PIA Erweiterung mit Produkteigenschaften und Target Market Daten für deutsche Marktanforderungen</xs:documentation>
         <xs:documentation xml:lang="fr">Extension PRIIPs European Product Template (EPT) PIA spécifique à l'Allemagne contenant les caractéristiques du produit et données target market pour les exigences du marché allemand</xs:documentation>
         <xs:documentation xml:lang="nl">Duitsland-specifieke PRIIPs European Product Template (EPT) PIA uitbreiding met productkenmerken en target market gegevens voor Duitse marktvereisten</xs:documentation>
         <xs:documentation xml:lang="es">Extensión PRIIPs European Product Template (EPT) PIA específica de Alemania con características de producto y datos de target market para requisitos del mercado alemán</xs:documentation>
         <xs:documentation xml:lang="it">PRIIP specifici per la Germania Estensione PIA del modello di prodotto europeo (EPT) contenente le caratteristiche del prodotto e i dati del mercato di riferimento per i requisiti del mercato tedesco</xs:documentation>
         <xs:documentation xml:lang="cs">Rozšíření PRIIPs European Product Template (EPT) PIA specifické pro Německo obsahující charakteristiky produktu a údaje o cílovém trhu pro požadavky německého trhu</xs:documentation>
         <xs:documentation xml:lang="hu">Németország-specifikus PRIIPs European Product Template (EPT) PIA-bővítmény, amely termékjellemzőket és célpiaci adatokat tartalmaz a német piaci követelményekhez</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="Characteristics">
            <xs:annotation>
               <xs:documentation xml:lang="en">Characteristics of the fund / portfolio</xs:documentation>
               <xs:documentation xml:lang="de">Characteristics von Fonds / Portfolio</xs:documentation>
               <xs:documentation xml:lang="fr">Characteristics de fonds / portefeuille</xs:documentation>
               <xs:documentation xml:lang="nl">Characteristics van fonds / portefeuille</xs:documentation>
               <xs:documentation xml:lang="es">Características del fondo / cartera</xs:documentation>
               <xs:documentation xml:lang="it">Caratteristiche del fondo/portafoglio</xs:documentation>
               <xs:documentation xml:lang="cs">Charakteristiky fondu / portfolia</xs:documentation>
               <xs:documentation xml:lang="hu">Az alap / portfólió jellemzői</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="BondsWeight" type="xs:decimal">
                     <xs:annotation>
                        <xs:documentation xml:lang="en">06010-Proportion (weight) of bonds within the fund/portfolio measured in percentage of market value.</xs:documentation>
                        <xs:documentation xml:lang="de">06010-Proportion (Gewicht) von bonds within Fonds/Portfolio measured in Prozentsatz von Marktwert.</xs:documentation>
                        <xs:documentation xml:lang="fr">06010-Proportion (poids) de bonds within fonds/portefeuille measured dans pourcentage de valeur de marché.</xs:documentation>
                        <xs:documentation xml:lang="nl">06010-Proportion (gewicht) van bonds within fonds/portefeuille measured in percentage van marktwaarde.</xs:documentation>
                        <xs:documentation xml:lang="es">06010-Proporción (peso) de bonos dentro del fondo/cartera medido en porcentaje del valor de mercado.</xs:documentation>
                        <xs:documentation xml:lang="it">06010-Proporzione (peso) delle obbligazioni all'interno del fondo/portafoglio misurata in percentuale del valore di mercato.</xs:documentation>
                        <xs:documentation xml:lang="cs">06010-Podíl (váha) dluhopisů ve fondu/portfoliu měřený v procentech tržní hodnoty.</xs:documentation>
                        <xs:documentation xml:lang="hu">06010 - A kötvények aránya (súlya) az alapon/portfólión belül, a piaci érték százalékában mérve.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="AnnualizedReturnVolatility" type="xs:decimal">
                     <xs:annotation>
                        <xs:documentation xml:lang="en">06020-Annualized daily volatility of the fund / portfolio based on the last 250 trading days or, if valuation frequency is lower than daily, the volatility is based on the valuation frequency and annualized.</xs:documentation>
                        <xs:documentation xml:lang="de">06020-Annualized täglich Volatilität von Fonds / Portfolio based on last 250 trading days oder, wenn Bewertung frequency ist lower than täglich, Volatilität ist based on Bewertung frequency und annualized.</xs:documentation>
                        <xs:documentation xml:lang="fr">06020-Annualized quotidien volatilité de fonds / portefeuille based on last 250 trading days ou, si évaluation frequency est lower than quotidien, volatilité est based on évaluation frequency et annualized.</xs:documentation>
                        <xs:documentation xml:lang="nl">06020-Geannualiseerde dagelijkse volatiliteit van het fonds / de portefeuille op basis van de laatste 250 handelsdagen of, indien de waarderingsfrequentie lager is dan dagelijks, is de volatiliteit gebaseerd op de waarderingsfrequentie en geannualiseerd.</xs:documentation>
                        <xs:documentation xml:lang="es">06020-Volatilidad diaria anualizada del fondo / cartera basada en los últimos 250 días de negociación o, si la frecuencia de valoración es menor que diaria, la volatilidad se basa en la frecuencia de valoración y se anualiza.</xs:documentation>
                        <xs:documentation xml:lang="it">06020-Volatilità giornaliera annualizzata del fondo/portafoglio sulla base degli ultimi 250 giorni di negoziazione oppure, se la frequenza di valutazione è inferiore a quella giornaliera, la volatilità è basata sulla frequenza di valutazione e annualizzata.</xs:documentation>
                        <xs:documentation xml:lang="cs">06020-Anualizovaná denní volatilita fondu / portfolia na základě posledních 250 obchodních dnů; pokud je frekvence oceňování nižší než denní, volatilita vychází z frekvence oceňování a je anualizována.</xs:documentation>
                        <xs:documentation xml:lang="hu">06020 - Az alap / portfólió annualizált napi volatilitása az utolsó 250 kereskedési nap alapján, vagy ha az értékelési gyakoriság a naposnál alacsonyabb, a volatilitás az értékelési gyakoriságon alapul és annualizált.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="DurationBonds" type="xs:decimal">
                     <xs:annotation>
                        <xs:documentation xml:lang="en">06030-Asset prices weighted Macaulay-Duration in years of the fund / portfolio</xs:documentation>
                        <xs:documentation xml:lang="de">06030-Vermögenswert prices weighted Macaulay-Duration in years von Fonds / Portfolio</xs:documentation>
                        <xs:documentation xml:lang="fr">06030-Actif prices weighted Macaulay-Duration dans years de fonds / portefeuille</xs:documentation>
                        <xs:documentation xml:lang="nl">06030-Actief prices weighted Macaulay-Duration in years van fonds / portefeuille</xs:documentation>
                        <xs:documentation xml:lang="es">06030-Precios de activos ponderados Macaulay-Duration en años del fondo / cartera</xs:documentation>
                        <xs:documentation xml:lang="it">06030-Prezzi degli asset ponderati Macaulay-Durata in anni del fondo/portafoglio</xs:documentation>
                        <xs:documentation xml:lang="cs">06030-Macaulay-Duration fondu / portfolia v letech, vážená cenami aktiv</xs:documentation>
                        <xs:documentation xml:lang="hu">06030 - Az alap / portfólió eszközárakkal súlyozott Macaulay-Duration-je években</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element name="CapitalPreservation">
            <xs:annotation>
               <xs:documentation xml:lang="en">Additional information for capital preservation funds/portfolio</xs:documentation>
               <xs:documentation xml:lang="de">Zusätzlich Information für capital preservation funds/Portfolio</xs:documentation>
               <xs:documentation xml:lang="fr">Supplémentaire information pour capital preservation funds/portefeuille</xs:documentation>
               <xs:documentation xml:lang="nl">Aanvullend informatie voor capital preservation funds/portefeuille</xs:documentation>
               <xs:documentation xml:lang="es">Información adicional para fondos/cartera de preservación de capital</xs:documentation>
