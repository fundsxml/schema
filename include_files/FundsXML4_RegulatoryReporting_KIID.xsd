               <xs:documentation xml:lang="da">Identifikatorer for fond eller Share Class til nem forbindelse til andre fonds- eller Share Class-data</xs:documentation>
               <xs:documentation xml:lang="pl">Identyfikatory funduszu lub Share Class umożliwiające łatwe powiązanie z innymi danymi funduszu lub Share Class</xs:documentation>
            </xs:annotation>
