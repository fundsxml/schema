					<xs:documentation xml:lang="it">Valore nominale/unità</xs:documentation>
					<xs:documentation xml:lang="cs">Nominální hodnota / jednotky</xs:documentation>
					<xs:documentation xml:lang="hu">Névérték / egységek</xs:documentation>
					<xs:documentation xml:lang="da">Nominel værdi / andele</xs:documentation>
					<xs:documentation xml:lang="pl">Wartość nominalna / jednostki</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ReferenceNumber" type="Text100Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">External reference number of earning transaction</xs:documentation>
					<xs:documentation xml:lang="de">Externe Referenznummer der Erträgnisbuchung</xs:documentation>
					<xs:documentation xml:lang="fr">Externe référence numéro de earning transaction</xs:documentation>
					<xs:documentation xml:lang="nl">Extern referentie nummer van earning transactie</xs:documentation>
