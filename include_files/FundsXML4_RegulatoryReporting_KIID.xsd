               <xs:documentation xml:lang="it">Testi fissi della copertina. Articoli 4.2 e 4.3</xs:documentation>
               <xs:documentation xml:lang="cs">Pevné texty titulní strany. Čl. 4.2 a 4.3</xs:documentation>
