<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:altova="http://www.altova.com/xml-schema-extensions"
           xmlns:vc="http://www.w3.org/2007/XMLSchema-versioning"
           xmlns:xs="http://www.w3.org/2001/XMLSchema"
           attributeFormDefault="unqualified"
           elementFormDefault="qualified"
           vc:minVersion="1.1">
   <xs:include schemaLocation="FundsXML4_Core.xsd"/>
   <xs:complexType name="AssetManagementClosedDataType">
      <xs:annotation>
         <xs:documentation xml:lang="en">Data of the investment or asset management company for closed-ended funds</xs:documentation>
         <xs:documentation xml:lang="de">Daten der Investmentgesellschaft oder Vermögensverwaltung für geschlossene Funds</xs:documentation>
         <xs:documentation xml:lang="fr">Données de investissement ou actif management company pour fermé-ended funds</xs:documentation>
         <xs:documentation xml:lang="nl">Gegevens van belegging van actief management company voor gesloten-ended funds</xs:documentation>
         <xs:documentation xml:lang="es">Datos de la sociedad de inversión o gestora de activos para fondos cerrados</xs:documentation>
         <xs:documentation xml:lang="it">Dati della società di investimento o di gestione del risparmio per i fondi chiusi</xs:documentation>
         <xs:documentation xml:lang="cs">Data of the investment or asset management company for closed-ended funds</xs:documentation>

         <xs:documentation xml:lang="hu">A befektetési vagy vagyonkezelő társaság adatai zárt végű alapokhoz</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="OwnFunds">
         <xs:annotation>
            <xs:documentation xml:lang="en">Own funds of the asset management company (closed-ended)</xs:documentation>
            <xs:documentation xml:lang="de">Eigene Fonds der Vermögensverwaltungsgesellschaft (geschlossen)</xs:documentation>
            <xs:documentation xml:lang="fr">Fonds propres de la société de gestion d'actifs (fermés)</xs:documentation>
            <xs:documentation xml:lang="nl">Eigen fondsen van de vermogensbeheermaatschappij (gesloten)</xs:documentation>
            <xs:documentation xml:lang="es">Fondos propios de la sociedad gestora de activos (cerrados)</xs:documentation>
            <xs:documentation xml:lang="it">Fondi propri della società di gestione patrimoniale (chiusi)</xs:documentation>
            <xs:documentation xml:lang="hu">A vagyonkezelő társaság saját alapjai (zárt végű)</xs:documentation>
            <xs:documentation xml:lang="cs">Vlastní fondy společnosti pro správu aktiv (uzavřené)</xs:documentation>
         </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="Number" type="xs:int">
                     <xs:annotation>
                        <xs:documentation xml:lang="en">Number of funds</xs:documentation>
                        <xs:documentation xml:lang="de">Anzahl der Funds</xs:documentation>
                        <xs:documentation xml:lang="fr">Numéro de funds</xs:documentation>
                        <xs:documentation xml:lang="nl">Nummer van funds</xs:documentation>
                        <xs:documentation xml:lang="es">Número de fondos</xs:documentation>
                        <xs:documentation xml:lang="it">Numero di fondi</xs:documentation>
                        <xs:documentation xml:lang="cs">Počet funds</xs:documentation>

                        <xs:documentation xml:lang="hu">Alapok száma</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="AssetInformation" type="AssetManagementCompanyFundAssetsType">
                  <xs:annotation>
                     <xs:documentation xml:lang="en">Asset information for the fund (number of funds, net assets, gross assets)</xs:documentation>
                     <xs:documentation xml:lang="de">Vermögensinformationen des Fonds (Anzahl der Fonds, Nettovermögen, Bruttovermögen)</xs:documentation>
                     <xs:documentation xml:lang="fr">Informations sur les actifs du fonds (nombre de fonds, actifs nets, actifs bruts)</xs:documentation>
                     <xs:documentation xml:lang="nl">Vermogensinformatie van het fonds (aantal fondsen, nettovermogen, brutovermogen)</xs:documentation>
                     <xs:documentation xml:lang="es">Información de activos del fondo (número de fondos, activos netos, activos brutos)</xs:documentation>
                     <xs:documentation xml:lang="it">Informazioni sugli attivi del fondo (numero di fondi, patrimonio netto, patrimonio lordo)</xs:documentation>
                     <xs:documentation xml:lang="hu">Az alap eszközinformációi (alapok száma, nettó eszközök, bruttó eszközök)</xs:documentation>
                     <xs:documentation xml:lang="cs">Informace o aktivech fondu (počet fondů, čistá aktiva, hrubá aktiva)</xs:documentation>
                  </xs:annotation>
                  </xs:element>
                  <xs:element name="NetSalesInformation" type="AssetManagementCompanySalesType">
                  <xs:annotation>
                     <xs:documentation xml:lang="en">Net sales information for the fund</xs:documentation>
                     <xs:documentation xml:lang="de">Nettomittelaufkommen des Fonds</xs:documentation>
                     <xs:documentation xml:lang="fr">Informations sur les ventes nettes du fonds</xs:documentation>
                     <xs:documentation xml:lang="nl">Netto-verkoop informatie van het fonds</xs:documentation>
                     <xs:documentation xml:lang="es">Información de ventas netas del fondo</xs:documentation>
                     <xs:documentation xml:lang="it">Informazioni sulle vendite nette del fondo</xs:documentation>
                     <xs:documentation xml:lang="hu">Az alap nettó értékesítési információi</xs:documentation>
                     <xs:documentation xml:lang="cs">Informace o čistých prodejích fondu</xs:documentation>
                  </xs:annotation>
                  </xs:element>
                  <xs:element name="Segmentation">
                     <xs:annotation>
                        <xs:documentation xml:lang="en">Information about the segmentation of funds</xs:documentation>
                        <xs:documentation xml:lang="de">Informationen über die Segmentierung von Funds</xs:documentation>
                        <xs:documentation xml:lang="fr">Information about segmentation de funds</xs:documentation>
                        <xs:documentation xml:lang="nl">Informatie about segmentation van funds</xs:documentation>
                        <xs:documentation xml:lang="es">Información sobre la segmentación de fondos</xs:documentation>
                        <xs:documentation xml:lang="it">Informazioni sulla segmentazione dei fondi</xs:documentation>
                        <xs:documentation xml:lang="cs">Information about the segmentation of funds</xs:documentation>

                        <xs:documentation xml:lang="hu">Információ az alapok szegmentációjáról</xs:documentation>
                     </xs:annotation>
                     <xs:complexType>
                        <xs:sequence>
                           <xs:element name="FundsWithoutSegments" type="xs:int">
                              <xs:annotation>
                                 <xs:documentation xml:lang="en">Number of funds without segments or comparable subunits</xs:documentation>
                                 <xs:documentation xml:lang="de">Anzahl der Funds ohne Segmente oder vergleichbare Untereinheiten</xs:documentation>
                                 <xs:documentation xml:lang="fr">Numéro de funds sans segments ou comparable subunits</xs:documentation>
                                 <xs:documentation xml:lang="nl">Nummer van funds zonder segments van comparable subunits</xs:documentation>
                                 <xs:documentation xml:lang="es">Número de fondos without segments or comparable subunits</xs:documentation>
                                 <xs:documentation xml:lang="it">Numero di fondi senza segmenti o sottounità comparabili</xs:documentation>
                                 <xs:documentation xml:lang="cs">Počet funds without segments or comparable subunits</xs:documentation>

                                 <xs:documentation xml:lang="hu">Szegmensek vagy összehasonlítható alegységek nélküli alapok száma</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                           <xs:element name="FundsWithSegments">
                              <xs:annotation>
                                 <xs:documentation xml:lang="en">Data about the funds with segments of an investment or asset management company</xs:documentation>
                                 <xs:documentation xml:lang="de">Daten über die Funds mit Segmenten einer Investmentgesellschaft oder Vermögensverwaltung</xs:documentation>
                                 <xs:documentation xml:lang="fr">Données about funds avec segments de un investissement ou actif management company</xs:documentation>
                                 <xs:documentation xml:lang="nl">Gegevens about funds met segments van een belegging van actief management company</xs:documentation>
                                 <xs:documentation xml:lang="es">Datos sobre los fondos con segmentos de una sociedad de inversión o gestora de activos</xs:documentation>
                                 <xs:documentation xml:lang="it">Dati sui fondi con segmenti di una società di investimento o di gestione patrimoniale</xs:documentation>
                                 <xs:documentation xml:lang="cs">Data about the funds with segments of an investment or asset management company</xs:documentation>

                                 <xs:documentation xml:lang="hu">Adatok a befektetési vagy vagyonkezelő társaság szegmensekkel rendelkező alapjairól</xs:documentation>
                              </xs:annotation>
                              <xs:complexType>
                                 <xs:sequence>
                                    <xs:element name="Number" type="xs:int">
                                       <xs:annotation>
                                          <xs:documentation xml:lang="en">Number of funds with segments or comparable subunits</xs:documentation>
                                          <xs:documentation xml:lang="de">Anzahl der Funds mit Segmenten oder vergleichbaren Untereinheiten</xs:documentation>
                                          <xs:documentation xml:lang="fr">Numéro de funds avec segments ou comparable subunits</xs:documentation>
                                          <xs:documentation xml:lang="nl">Nummer van funds met segments van comparable subunits</xs:documentation>
                                          <xs:documentation xml:lang="es">Número de fondos with segments or comparable subunits</xs:documentation>
                                          <xs:documentation xml:lang="it">Numero di fondi con segmenti o sottounità comparabili</xs:documentation>
                                          <xs:documentation xml:lang="cs">Počet funds with segments or comparable subunits</xs:documentation>

                                          <xs:documentation xml:lang="hu">Szegmensekkel vagy összehasonlítható alegységekkel rendelkező alapok száma</xs:documentation>
                                       </xs:annotation>
                                    </xs:element>
                                    <xs:element name="NumberOfSegments" type="xs:int">
                                       <xs:annotation>
                                          <xs:documentation xml:lang="en">Number of segments or comparable subunits</xs:documentation>
                                          <xs:documentation xml:lang="de">Anzahl der Segmente oder vergleichbaren Untereinheiten</xs:documentation>
                                          <xs:documentation xml:lang="fr">Numéro de segments ou comparable subunits</xs:documentation>
                                          <xs:documentation xml:lang="nl">Nummer van segments van comparable subunits</xs:documentation>
                                          <xs:documentation xml:lang="es">Número de segments or comparable subunits</xs:documentation>
                                          <xs:documentation xml:lang="it">Numero di segmenti o subunità comparabili</xs:documentation>
                                          <xs:documentation xml:lang="cs">Počet segments or comparable subunits</xs:documentation>

                                          <xs:documentation xml:lang="hu">Szegmensek vagy összehasonlítható alegységek száma</xs:documentation>
                                       </xs:annotation>
                                    </xs:element>
                                    <xs:element name="NetAssetsSegments" type="AssetManagementCompanyFundAssetsType">
                                       <xs:annotation>
                                          <xs:documentation xml:lang="en">Net assets of funds with segments or comparable subunits</xs:documentation>
                                          <xs:documentation xml:lang="de">Nettovermögen der Funds mit Segmenten oder vergleichbaren Untereinheiten</xs:documentation>
                                          <xs:documentation xml:lang="fr">Net assets de funds avec segments ou comparable subunits</xs:documentation>
                                          <xs:documentation xml:lang="nl">Netto assets van funds met segments van comparable subunits</xs:documentation>
                                          <xs:documentation xml:lang="es">Net activos of fondos with segments or comparable subunits</xs:documentation>
                                          <xs:documentation xml:lang="it">Patrimonio netto dei fondi con segmenti o sottounità comparabili</xs:documentation>
                                          <xs:documentation xml:lang="cs">Net assets of funds with segments or comparable subunits</xs:documentation>

                                          <xs:documentation xml:lang="hu">Szegmensekkel vagy összehasonlítható alegységekkel rendelkező alapok nettó eszközértéke</xs:documentation>
                                       </xs:annotation>
                                    </xs:element>
                                 </xs:sequence>
                              </xs:complexType>
                           </xs:element>
                           <xs:element name="NumberOfAdministrativeUnits" type="xs:int">
                              <xs:annotation>
                                 <xs:documentation xml:lang="en">Total number of administrative units, which is the sum of the number of funds without segments and comparable subunits and the number of segments or comparable subunits</xs:documentation>
                                 <xs:documentation xml:lang="de">Gesamtanzahl der Verwaltungseinheiten, die sich aus der Anzahl der Funds ohne Segmente und vergleichbare Untereinheiten sowie der Anzahl der Segmente oder vergleichbaren Untereinheiten zusammensetzt</xs:documentation>
                                 <xs:documentation xml:lang="fr">Total numéro de administrative units, qui est sum de numéro de funds sans segments et comparable subunits et numéro de segments ou comparable subunits</xs:documentation>
                                 <xs:documentation xml:lang="nl">Totaal nummer van administrative units, welke is sum van nummer van funds zonder segments en comparable subunits en nummer van segments van comparable subunits</xs:documentation>
                                 <xs:documentation xml:lang="es">Número total de unidades administrativas, que es la suma del número de fondos sin segmentos y subunidades comparables y el número de segmentos o subunidades comparables</xs:documentation>
                                 <xs:documentation xml:lang="it">Numero totale di unità amministrative, ovvero la somma del numero di fondi senza segmenti e sottounità comparabili e del numero di segmenti o sottounità comparabili</xs:documentation>
                                 <xs:documentation xml:lang="cs">Celkový počet administrative units, which is the sum of the number of funds without segments and comparable subunits and the number of segments or comparable subunits</xs:documentation>

                                 <xs:documentation xml:lang="hu">Adminisztratív egységek összesített száma, amely a szegmensek és összehasonlítható alegységek nélküli alapok számának és a szegmensek vagy összehasonlítható alegységek számának összege</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                        </xs:sequence>
                     </xs:complexType>
                  </xs:element>
                  <xs:element minOccurs="0" name="PortfoliomanagementByThirdParties">
                     <xs:annotation>
                        <xs:documentation xml:lang="en">Information about the structure of the respective investment or asset management company with regard to portfoliomanagement or advise by third parties</xs:documentation>
                        <xs:documentation xml:lang="de">Informationen über die Struktur der jeweiligen Investmentgesellschaft oder Vermögensverwaltung hinsichtlich des Portfoliomanagements oder der Beratung durch Dritte</xs:documentation>
                        <xs:documentation xml:lang="fr">Information about structure de respective investissement ou actif management company avec regard à portfoliomanagement ou advise par third parties</xs:documentation>
                        <xs:documentation xml:lang="nl">Informatie about structuur van respective belegging van actief management company met regard naar portfoliomanagement van advise door third parties</xs:documentation>
                        <xs:documentation xml:lang="es">Información sobre la estructura de la respectiva sociedad de inversión o gestora de activos con respecto a la gestión de cartera o el asesoramiento por terceros</xs:documentation>
                        <xs:documentation xml:lang="it">Informazioni sulla struttura della rispettiva società di investimento o di gestione patrimoniale per quanto riguarda la gestione del portafoglio o consulenza di terzi</xs:documentation>
                        <xs:documentation xml:lang="cs">Information about the structure of the respective investment or asset management company with regard to portfoliomanagement or advise by third parties</xs:documentation>

                        <xs:documentation xml:lang="hu">Információ a befektetési vagy vagyonkezelő társaság struktúrájáról a portfóliókezelés vagy harmadik felek általi tanácsadás tekintetében</xs:documentation>
                     </xs:annotation>
                     <xs:complexType>
                        <xs:sequence>
                           <xs:element name="TotalAdministrativeUnits" type="FundStatisticClosedFundType">
                              <xs:annotation>
                                 <xs:documentation xml:lang="en">Data about the total of the respective administrative units</xs:documentation>
                                 <xs:documentation xml:lang="de">Daten über die Gesamtheit der jeweiligen Verwaltungseinheiten</xs:documentation>
                                 <xs:documentation xml:lang="fr">Données about total de respective administrative units</xs:documentation>
                                 <xs:documentation xml:lang="nl">Gegevens about totaal van respective administrative units</xs:documentation>
                                 <xs:documentation xml:lang="es">Datos sobre el total de las respectivas unidades administrativas</xs:documentation>
                                 <xs:documentation xml:lang="it">Dati sul totale delle rispettive unità amministrative</xs:documentation>
                                 <xs:documentation xml:lang="cs">Data about the total of the respective administrative units</xs:documentation>

                                 <xs:documentation xml:lang="hu">A megfelelő adminisztratív egységek összesített adatai</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                           <xs:element minOccurs="0" name="WithinAffiliatedGroup">
                              <xs:annotation>
                                 <xs:documentation xml:lang="en">Data about the respective administrative units for which the portfoliomanagement or advise is done by a third party which is part of the affiliated company group</xs:documentation>
                                 <xs:documentation xml:lang="de">Daten über die jeweiligen Verwaltungseinheiten, deren Portfoliomanagement oder Beratung von einem Dritten durchgeführt wird, der Teil des verbundenen Unternehmenskreises ist</xs:documentation>
                                 <xs:documentation xml:lang="fr">Données about respective administrative units pour qui portfoliomanagement ou advise est done par un third party qui est part de affiliated company groupe</xs:documentation>
                                 <xs:documentation xml:lang="nl">Gegevens about respective administrative units voor welke portfoliomanagement van advise is done door een third party welke is part van affiliated company groep</xs:documentation>
                                 <xs:documentation xml:lang="es">Datos sobre las respectivas unidades administrativas para las cuales la gestión de cartera o el asesoramiento es realizado por un tercero que forma parte del grupo empresarial afiliado</xs:documentation>
                                 <xs:documentation xml:lang="it">Dati sulle rispettive unità amministrative per le quali la gestione del portafoglio o la consulenza viene effettuata da un terzo che fa parte del gruppo di società affiliate</xs:documentation>
                                 <xs:documentation xml:lang="cs">Data about the respective administrative units for which the portfoliomanagement or advise is done by a third party which is part of the affiliated company group</xs:documentation>

                                 <xs:documentation xml:lang="hu">Adatok azon adminisztratív egységekről, amelyek portfóliókezelését vagy tanácsadását a kapcsolt vállalatcsoport tagja végzi</xs:documentation>
                              </xs:annotation>
                              <xs:complexType>
                                 <xs:sequence>
                                    <xs:element name="TotalAdministrativeUnits" type="FundStatisticClosedFundType">
                                       <xs:annotation>
                                          <xs:documentation xml:lang="en">Data about the total of the respective administrative units</xs:documentation>
                                          <xs:documentation xml:lang="de">Daten über die Gesamtheit der jeweiligen Verwaltungseinheiten</xs:documentation>
                                          <xs:documentation xml:lang="fr">Données about total de respective administrative units</xs:documentation>
                                          <xs:documentation xml:lang="nl">Gegevens about totaal van respective administrative units</xs:documentation>
                                          <xs:documentation xml:lang="es">Datos sobre el total de las respectivas unidades administrativas</xs:documentation>
                                          <xs:documentation xml:lang="it">Dati sul totale delle rispettive unità amministrative</xs:documentation>
                                          <xs:documentation xml:lang="cs">Data about the total of the respective administrative units</xs:documentation>

                                          <xs:documentation xml:lang="hu">A megfelelő adminisztratív egységek összesített adatai</xs:documentation>
                                       </xs:annotation>
                                    </xs:element>
                                    <xs:element minOccurs="0"
                                                name="CompaniesInCountry"
                                                type="FundStatisticClosedFundType">
                                       <xs:annotation>
                                          <xs:documentation xml:lang="en">Data about the part of the total which is related to the companies within the respective country</xs:documentation>
                                          <xs:documentation xml:lang="de">Daten über den Teil der Gesamtheit, der sich auf Unternehmen im jeweiligen Land bezieht</xs:documentation>
                                          <xs:documentation xml:lang="fr">Données about part de total qui est related à companies within respective pays</xs:documentation>
                                          <xs:documentation xml:lang="nl">Gegevens about part van totaal welke is related naar companies within respective land</xs:documentation>
                                          <xs:documentation xml:lang="es">Datos sobre la parte del total relacionada con las sociedades dentro del país respectivo</xs:documentation>
                                          <xs:documentation xml:lang="it">Dati sulla parte del totale relativa alle aziende del rispettivo paese</xs:documentation>
                                          <xs:documentation xml:lang="cs">Data about the part of the total which is related to the companies within the respective country</xs:documentation>

                                          <xs:documentation xml:lang="hu">Az összesnek azon részére vonatkozó adatok, amely az adott országon belüli vállalatokhoz kapcsolódik</xs:documentation>
                                       </xs:annotation>
                                    </xs:element>
                                 </xs:sequence>
                              </xs:complexType>
                           </xs:element>
                           <xs:element minOccurs="0" name="OutsideAffiliatedGroup">
                              <xs:annotation>
                                 <xs:documentation xml:lang="en">Data about the respective administrative units for which the portfoliomanagement or advise is done by a third party which is not a part of the affiliated company group</xs:documentation>
                                 <xs:documentation xml:lang="de">Daten über die jeweiligen Verwaltungseinheiten, deren Portfoliomanagement oder Beratung von einem Dritten durchgeführt wird, der nicht Teil des verbundenen Unternehmenskreises ist</xs:documentation>
                                 <xs:documentation xml:lang="fr">Données about respective administrative units pour qui portfoliomanagement ou advise est done par un third party qui est pas un part de affiliated company groupe</xs:documentation>
                                 <xs:documentation xml:lang="nl">Gegevens about respective administrative units voor welke portfoliomanagement van advise is done door een third party welke is niet een part van affiliated company groep</xs:documentation>
                                 <xs:documentation xml:lang="es">Datos sobre las respectivas unidades administrativas para las cuales la gestión de cartera o el asesoramiento es realizado por un tercero que no forma parte del grupo empresarial afiliado</xs:documentation>
                                 <xs:documentation xml:lang="it">Dati sulle rispettive unità amministrative per le quali la gestione del portafoglio o la consulenza viene effettuata da un terzo che non fa parte del gruppo di società affiliate</xs:documentation>
                                 <xs:documentation xml:lang="cs">Data about the respective administrative units for which the portfoliomanagement or advise is done by a third party which is not a part of the affiliated company group</xs:documentation>

                                 <xs:documentation xml:lang="hu">Adatok azon adminisztratív egységekről, amelyek portfóliókezelését vagy tanácsadását nem a kapcsolt vállalatcsoport tagja végzi</xs:documentation>
                              </xs:annotation>
                              <xs:complexType>
                                 <xs:sequence>
                                    <xs:element name="TotalAdministrativeUnits" type="FundStatisticClosedFundType">
                                       <xs:annotation>
                                          <xs:documentation xml:lang="en">Data about the total of the respective administrative units</xs:documentation>
                                          <xs:documentation xml:lang="de">Daten über die Gesamtheit der jeweiligen Verwaltungseinheiten</xs:documentation>
                                          <xs:documentation xml:lang="fr">Données about total de respective administrative units</xs:documentation>
                                          <xs:documentation xml:lang="nl">Gegevens about totaal van respective administrative units</xs:documentation>
                                          <xs:documentation xml:lang="es">Datos sobre el total de las respectivas unidades administrativas</xs:documentation>
                                          <xs:documentation xml:lang="it">Dati sul totale delle rispettive unità amministrative</xs:documentation>
                                          <xs:documentation xml:lang="cs">Data about the total of the respective administrative units</xs:documentation>

                                          <xs:documentation xml:lang="hu">A megfelelő adminisztratív egységek összesített adatai</xs:documentation>
                                       </xs:annotation>
                                    </xs:element>
                                    <xs:element minOccurs="0"
                                                name="CompaniesInCountry"
                                                type="FundStatisticClosedFundType">
                                       <xs:annotation>
                                          <xs:documentation xml:lang="en">Data about the part of the total which is related to the companies within the respective country</xs:documentation>
                                          <xs:documentation xml:lang="de">Daten über den Teil der Gesamtheit, der sich auf Unternehmen im jeweiligen Land bezieht</xs:documentation>
                                          <xs:documentation xml:lang="fr">Données about part de total qui est related à companies within respective pays</xs:documentation>
                                          <xs:documentation xml:lang="nl">Gegevens about part van totaal welke is related naar companies within respective land</xs:documentation>
                                          <xs:documentation xml:lang="es">Datos sobre la parte del total relacionada con las sociedades dentro del país respectivo</xs:documentation>
                                          <xs:documentation xml:lang="it">Dati sulla parte del totale relativa alle aziende del rispettivo paese</xs:documentation>
                                          <xs:documentation xml:lang="cs">Data about the part of the total which is related to the companies within the respective country</xs:documentation>

                                          <xs:documentation xml:lang="hu">Az összesnek azon részére vonatkozó adatok, amely az adott országon belüli vállalatokhoz kapcsolódik</xs:documentation>
                                       </xs:annotation>
                                    </xs:element>
                                 </xs:sequence>
                              </xs:complexType>
                           </xs:element>
                        </xs:sequence>
                     </xs:complexType>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0" name="ThirdPartyFunds">
         <xs:annotation>
            <xs:documentation xml:lang="en">Third-party funds managed by the asset management company (closed-ended)</xs:documentation>
            <xs:documentation xml:lang="de">Fremdfonds, die von der Vermögensverwaltungsgesellschaft verwaltet werden (geschlossen)</xs:documentation>
            <xs:documentation xml:lang="fr">Fonds de tiers gérés par la société de gestion d'actifs (fermés)</xs:documentation>
            <xs:documentation xml:lang="nl">Fondsen van derden beheerd door de vermogensbeheermaatschappij (gesloten)</xs:documentation>
            <xs:documentation xml:lang="es">Fondos de terceros gestionados por la sociedad gestora de activos (cerrados)</xs:documentation>
            <xs:documentation xml:lang="it">Fondi di terzi gestiti dalla società di gestione patrimoniale (chiusi)</xs:documentation>
            <xs:documentation xml:lang="hu">A vagyonkezelő társaság által kezelt harmadik féltől származó alapok (zárt végű)</xs:documentation>
            <xs:documentation xml:lang="cs">Fondy třetích stran spravované společností pro správu aktiv (uzavřené)</xs:documentation>
         </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="PortfoliomanagementForThirdParty">
