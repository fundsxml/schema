<xs:schema xmlns:altova="http://www.altova.com/xml-schema-extensions" xmlns:vc="http://www.w3.org/2007/XMLSchema-versioning" xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" attributeFormDefault="unqualified" vc:minVersion="1.1">
	<xs:complexType name="AddressType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Address information including street, city, country and contact details</xs:documentation>
			<xs:documentation xml:lang="de">Adressinformationen einschließlich Straße, Stadt, Land und Kontaktdaten</xs:documentation>
			<xs:documentation xml:lang="fr">Informations d'adresse comprenant rue, ville, pays et coordonnées</xs:documentation>
			<xs:documentation xml:lang="nl">Adresinformatie inclusief straat, stad, land en contactgegevens</xs:documentation>
			<xs:documentation xml:lang="es">Información de dirección incluyendo calle, ciudad, país y datos de contacto</xs:documentation>
			<xs:documentation xml:lang="it">Informazioni sull'indirizzo, inclusi via, città, paese e dettagli di contatto</xs:documentation>
			<xs:documentation xml:lang="cs">Adresní informace včetně ulice, města, země a kontaktních údajů</xs:documentation>
			<xs:documentation xml:lang="hu">Címinformációk, beleértve az utcát, a várost, az országot és a kapcsolattartási adatokat</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="StreetName" type="Text256Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Name of the street</xs:documentation>
					<xs:documentation xml:lang="de">Straßenname</xs:documentation>
					<xs:documentation xml:lang="fr">Nom de la rue</xs:documentation>
					<xs:documentation xml:lang="nl">Naam van de straat</xs:documentation>
					<xs:documentation xml:lang="es">Nombre de la calle</xs:documentation>
					<xs:documentation xml:lang="it">Nome della strada</xs:documentation>
					<xs:documentation xml:lang="cs">Název ulice</xs:documentation>
					<xs:documentation xml:lang="hu">Az utca neve</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="StreetNumber" type="Text32Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Street number or building number</xs:documentation>
					<xs:documentation xml:lang="de">Hausnummer</xs:documentation>
					<xs:documentation xml:lang="fr">Numéro de rue ou numéro de bâtiment</xs:documentation>
					<xs:documentation xml:lang="nl">Huisnummer of gebouwnummer</xs:documentation>
					<xs:documentation xml:lang="es">Número de calle o número de edificio</xs:documentation>
					<xs:documentation xml:lang="it">Numero civico o numero civico</xs:documentation>
					<xs:documentation xml:lang="cs">Číslo ulice nebo číslo budovy</xs:documentation>
					<xs:documentation xml:lang="hu">Házszám vagy épületszám</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Building" type="Text256Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Building name or identifier</xs:documentation>
					<xs:documentation xml:lang="de">Gebäudebezeichnung</xs:documentation>
					<xs:documentation xml:lang="fr">Nom ou identifiant du bâtiment</xs:documentation>
					<xs:documentation xml:lang="nl">Naam of identificatie van het gebouw</xs:documentation>
					<xs:documentation xml:lang="es">Nombre o identificador del edificio</xs:documentation>
					<xs:documentation xml:lang="it">Nome o identificatore dell'edificio</xs:documentation>
					<xs:documentation xml:lang="cs">Název nebo identifikátor budovy</xs:documentation>
					<xs:documentation xml:lang="hu">Épület neve vagy azonosítója</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CityName" type="Text256Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Name of the city</xs:documentation>
					<xs:documentation xml:lang="de">Ortsname</xs:documentation>
					<xs:documentation xml:lang="fr">Nom de la ville</xs:documentation>
					<xs:documentation xml:lang="nl">Naam van de stad</xs:documentation>
					<xs:documentation xml:lang="es">Nombre de la ciudad</xs:documentation>
					<xs:documentation xml:lang="it">Nome della città</xs:documentation>
					<xs:documentation xml:lang="cs">Název města</xs:documentation>
					<xs:documentation xml:lang="hu">A város neve</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CityCode" type="Text32Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Postal code or ZIP code</xs:documentation>
					<xs:documentation xml:lang="de">Postleitzahl</xs:documentation>
					<xs:documentation xml:lang="fr">Code postal</xs:documentation>
					<xs:documentation xml:lang="nl">Postcode</xs:documentation>
					<xs:documentation xml:lang="es">Código postal</xs:documentation>
					<xs:documentation xml:lang="it">Codice postale o codice postale</xs:documentation>
					<xs:documentation xml:lang="cs">Poštovní směrovací číslo</xs:documentation>
					<xs:documentation xml:lang="hu">Irányítószám</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="State" type="Text256Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">State, province or region</xs:documentation>
					<xs:documentation xml:lang="de">Bundesland, Provinz oder Region</xs:documentation>
					<xs:documentation xml:lang="fr">État, province ou région</xs:documentation>
					<xs:documentation xml:lang="nl">Staat, provincie of regio</xs:documentation>
					<xs:documentation xml:lang="es">Estado, provincia o región</xs:documentation>
					<xs:documentation xml:lang="it">Stato, provincia o regione</xs:documentation>
					<xs:documentation xml:lang="cs">Stát, provincie nebo region</xs:documentation>
					<xs:documentation xml:lang="hu">Állam, tartomány vagy régió</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Country" type="ISOCountryCodeType">
				<xs:annotation>
					<xs:documentation xml:lang="en">ISO country code (ISO 3166-1 alpha-2)</xs:documentation>
					<xs:documentation xml:lang="de">ISO-Ländercode (ISO 3166-1 alpha-2)</xs:documentation>
					<xs:documentation xml:lang="fr">Code pays ISO (ISO 3166-1 alpha-2)</xs:documentation>
					<xs:documentation xml:lang="nl">ISO-landcode (ISO 3166-1 alpha-2)</xs:documentation>
					<xs:documentation xml:lang="es">Código de país ISO (ISO 3166-1 alpha-2)</xs:documentation>
					<xs:documentation xml:lang="it">Codice paese ISO (ISO 3166-1 alpha-2)</xs:documentation>
					<xs:documentation xml:lang="cs">ISO kód země (ISO 3166-1 alpha-2)</xs:documentation>
					<xs:documentation xml:lang="hu">ISO országkód (ISO 3166-1 alpha-2)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Phone" type="Text256Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Phone number</xs:documentation>
					<xs:documentation xml:lang="de">Telefonnummer</xs:documentation>
					<xs:documentation xml:lang="fr">Numéro de téléphone</xs:documentation>
					<xs:documentation xml:lang="nl">Telefoonnummer</xs:documentation>
					<xs:documentation xml:lang="es">Número de teléfono</xs:documentation>
					<xs:documentation xml:lang="it">Numero di telefono</xs:documentation>
					<xs:documentation xml:lang="cs">Telefonní číslo</xs:documentation>
					<xs:documentation xml:lang="hu">Telefonszám</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Fax" type="Text64Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Fax number</xs:documentation>
					<xs:documentation xml:lang="de">Faxnummer</xs:documentation>
					<xs:documentation xml:lang="fr">Numéro de fax</xs:documentation>
					<xs:documentation xml:lang="nl">Faxnummer</xs:documentation>
					<xs:documentation xml:lang="es">Número de fax</xs:documentation>
					<xs:documentation xml:lang="it">Numero di fax</xs:documentation>
					<xs:documentation xml:lang="cs">Číslo faxu</xs:documentation>
					<xs:documentation xml:lang="hu">Faxszám</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Email" type="EmailAddressType" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Email address</xs:documentation>
					<xs:documentation xml:lang="de">E-Mail-Adresse</xs:documentation>
					<xs:documentation xml:lang="fr">Adresse e-mail</xs:documentation>
					<xs:documentation xml:lang="nl">E-mailadres</xs:documentation>
					<xs:documentation xml:lang="es">Dirección de correo electrónico</xs:documentation>
					<xs:documentation xml:lang="it">Indirizzo e-mail</xs:documentation>
					<xs:documentation xml:lang="cs">E-mailová adresa</xs:documentation>
					<xs:documentation xml:lang="hu">E-mail cím</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Homepage" type="xs:anyURI" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Website URL</xs:documentation>
					<xs:documentation xml:lang="de">Website-URL</xs:documentation>
					<xs:documentation xml:lang="fr">URL du site web</xs:documentation>
					<xs:documentation xml:lang="nl">Website-URL</xs:documentation>
					<xs:documentation xml:lang="es">URL del sitio web</xs:documentation>
					<xs:documentation xml:lang="it">URL del sito web</xs:documentation>
					<xs:documentation xml:lang="cs">URL webové stránky</xs:documentation>
					<xs:documentation xml:lang="hu">Weboldal URL</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="AmountType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Amount in different currencies</xs:documentation>
			<xs:documentation xml:lang="de">Betrag in verschiedenen Währungen</xs:documentation>
			<xs:documentation xml:lang="fr">Montant dans différentes devises</xs:documentation>
			<xs:documentation xml:lang="nl">Bedrag in verschillende valuta's</xs:documentation>
			<xs:documentation xml:lang="es">Importe en diferentes divisas</xs:documentation>
			<xs:documentation xml:lang="it">Importo in diverse valute</xs:documentation>
			<xs:documentation xml:lang="cs">Částka v různých měnách</xs:documentation>
			<xs:documentation xml:lang="hu">Összeg különböző pénznemekben</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Amount" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation xml:lang="en">Amounts in currency as defined in attribute</xs:documentation>
					<xs:documentation xml:lang="de">Betrag in frei wählbarer Währung</xs:documentation>
					<xs:documentation xml:lang="fr">Montants dans la devise définie par l'attribut</xs:documentation>
					<xs:documentation xml:lang="nl">Bedragen in de valuta zoals gedefinieerd in het attribuut</xs:documentation>
					<xs:documentation xml:lang="es">Importes en divisa según definido en atributo</xs:documentation>
					<xs:documentation xml:lang="it">Importi in valuta come definito nell'attributo</xs:documentation>
					<xs:documentation xml:lang="cs">Částky v měně podle definice v atributu</xs:documentation>
					<xs:documentation xml:lang="hu">Összegek pénznemben az attribútumban meghatározottak szerint</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:simpleContent>
						<xs:extension base="xs:decimal">
							<xs:attribute name="ccy" type="ISOCurrencyCodeType" use="required">
								<xs:annotation>
									<xs:documentation xml:lang="en">Currency code (ISO 4217)</xs:documentation>
									<xs:documentation xml:lang="de">Währungscode (ISO 4217)</xs:documentation>
									<xs:documentation xml:lang="fr">Code devise (ISO 4217)</xs:documentation>
									<xs:documentation xml:lang="nl">Valutacode (ISO 4217)</xs:documentation>
									<xs:documentation xml:lang="es">Código de divisa (ISO 4217)</xs:documentation>
									<xs:documentation xml:lang="it">Codice valuta (ISO 4217)</xs:documentation>
									<xs:documentation xml:lang="cs">Kód měny (ISO 4217)</xs:documentation>
									<xs:documentation xml:lang="hu">Pénznemkód (ISO 4217)</xs:documentation>
								</xs:annotation>
							</xs:attribute>
						</xs:extension>
					</xs:simpleContent>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="AttributesType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Container for multiple attributes</xs:documentation>
			<xs:documentation xml:lang="de">Container für mehrere Attribute</xs:documentation>
			<xs:documentation xml:lang="fr">Conteneur pour plusieurs attributs</xs:documentation>
			<xs:documentation xml:lang="nl">Container voor meerdere attributen</xs:documentation>
			<xs:documentation xml:lang="es">Contenedor para múltiples atributos</xs:documentation>
			<xs:documentation xml:lang="it">Contenitore per più attributi</xs:documentation>
			<xs:documentation xml:lang="cs">Kontejner pro více atributů</xs:documentation>
			<xs:documentation xml:lang="hu">Tároló több attribútum számára</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Attribute" type="AttributeType" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation xml:lang="en">Single attribute entry with name, type and value</xs:documentation>
					<xs:documentation xml:lang="de">Einzelner Attributeintrag mit Name, Typ und Wert</xs:documentation>
					<xs:documentation xml:lang="fr">Entrée d'attribut unique avec nom, type et valeur</xs:documentation>
					<xs:documentation xml:lang="nl">Enkel attribuutitem met naam, type en waarde</xs:documentation>
					<xs:documentation xml:lang="es">Entrada de atributo individual con nombre, tipo y valor</xs:documentation>
					<xs:documentation xml:lang="it">Voce attributo singola con nome, tipo e valore</xs:documentation>
					<xs:documentation xml:lang="cs">Jednotlivý záznam atributu s názvem, typem a hodnotou</xs:documentation>
					<xs:documentation xml:lang="hu">Egyedi attribútum bejegyzés névvel, típussal és értékkel</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="AttributeType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Generic attribute with name, type and value</xs:documentation>
			<xs:documentation xml:lang="de">Generisches Attribut mit Name, Typ und Wert</xs:documentation>
			<xs:documentation xml:lang="fr">Attribut générique avec nom, type et valeur</xs:documentation>
			<xs:documentation xml:lang="nl">Generiek attribuut met naam, type en waarde</xs:documentation>
			<xs:documentation xml:lang="es">Atributo genérico con nombre, tipo y valor</xs:documentation>
			<xs:documentation xml:lang="it">Attributo generico con nome, tipo e valore</xs:documentation>
			<xs:documentation xml:lang="cs">Generický atribut s názvem, typem a hodnotou</xs:documentation>
			<xs:documentation xml:lang="hu">Általános attribútum névvel, típussal és értékkel</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Name" type="Text256Type">
				<xs:annotation>
					<xs:documentation xml:lang="en">Name of attribute</xs:documentation>
					<xs:documentation xml:lang="de">Name des Attributs</xs:documentation>
					<xs:documentation xml:lang="fr">Nom de l'attribut</xs:documentation>
					<xs:documentation xml:lang="nl">Naam van het attribuut</xs:documentation>
					<xs:documentation xml:lang="es">Nombre del atributo</xs:documentation>
					<xs:documentation xml:lang="it">Nome dell'attributo</xs:documentation>
					<xs:documentation xml:lang="cs">Název atributu</xs:documentation>
					<xs:documentation xml:lang="hu">Az attribútum neve</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Type">
				<xs:annotation>
					<xs:documentation xml:lang="en">Type of attribute:
T ... Text
N ... Number
D ... Date
B ... Boolean</xs:documentation>
					<xs:documentation xml:lang="de">Typ des Attributs:
T ... Text
N ... Zahl
D ... Datum
B ... Boolean</xs:documentation>
					<xs:documentation xml:lang="fr">Type d'attribut :
T ... Texte
N ... Nombre
D ... Date
B ... Booléen</xs:documentation>
					<xs:documentation xml:lang="nl">Type attribuut:
T ... Tekst
N ... Nummer
D ... Datum
B ... Boolean</xs:documentation>
					<xs:documentation xml:lang="es">Tipo de atributo:
T ... Texto
N ... Número
D ... Fecha
B ... Booleano</xs:documentation>
					<xs:documentation xml:lang="it">Tipo di attributo:
T... Testo
N...Numero
D... Data
B ... Booleano</xs:documentation>
					<xs:documentation xml:lang="cs">Typ atributu:
T ... Text
N ... Číslo
D ... Datum
B ... Boolean</xs:documentation>
					<xs:documentation xml:lang="hu">Attribútum típusa:
T ... Szöveg
N ... Szám
D ... Dátum
B ... Logikai</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:length value="1"/>
						<xs:enumeration value="T"/>
						<xs:enumeration value="N"/>
						<xs:enumeration value="D"/>
						<xs:enumeration value="B"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:choice>
				<xs:element name="ValueText" type="xs:string">
					<xs:annotation>
						<xs:documentation xml:lang="en">Text value of the attribute</xs:documentation>
						<xs:documentation xml:lang="de">Textwert des Attributs</xs:documentation>
						<xs:documentation xml:lang="fr">Valeur textuelle de l'attribut</xs:documentation>
						<xs:documentation xml:lang="nl">Tekstwaarde van het attribuut</xs:documentation>
						<xs:documentation xml:lang="es">Valor de texto del atributo</xs:documentation>
						<xs:documentation xml:lang="it">Valore testuale dell'attributo</xs:documentation>
						<xs:documentation xml:lang="cs">Textová hodnota atributu</xs:documentation>
						<xs:documentation xml:lang="hu">Az attribútum szöveges értéke</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="ValueNumber" type="xs:decimal">
					<xs:annotation>
						<xs:documentation xml:lang="en">Numeric value of the attribute</xs:documentation>
						<xs:documentation xml:lang="de">Numerischer Wert des Attributs</xs:documentation>
						<xs:documentation xml:lang="fr">Valeur numérique de l'attribut</xs:documentation>
						<xs:documentation xml:lang="nl">Numerieke waarde van het attribuut</xs:documentation>
						<xs:documentation xml:lang="es">Valor numérico del atributo</xs:documentation>
						<xs:documentation xml:lang="it">Valore numerico dell'attributo</xs:documentation>
						<xs:documentation xml:lang="cs">Číselná hodnota atributu</xs:documentation>
						<xs:documentation xml:lang="hu">Az attribútum numerikus értéke</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="ValueDate" type="xs:date">
					<xs:annotation>
						<xs:documentation xml:lang="en">Date value of the attribute</xs:documentation>
						<xs:documentation xml:lang="de">Datumswert des Attributs</xs:documentation>
						<xs:documentation xml:lang="fr">Valeur de date de l'attribut</xs:documentation>
						<xs:documentation xml:lang="nl">Datumwaarde van het attribuut</xs:documentation>
						<xs:documentation xml:lang="es">Valor de fecha del atributo</xs:documentation>
						<xs:documentation xml:lang="it">Valore data dell'attributo</xs:documentation>
						<xs:documentation xml:lang="cs">Datumová hodnota atributu</xs:documentation>
						<xs:documentation xml:lang="hu">Az attribútum dátumértéke</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="ValueBoolean" type="xs:boolean">
					<xs:annotation>
						<xs:documentation xml:lang="en">Boolean value of the attribute</xs:documentation>
						<xs:documentation xml:lang="de">Boolescher Wert des Attributs</xs:documentation>
						<xs:documentation xml:lang="fr">Valeur booléenne de l'attribut</xs:documentation>
						<xs:documentation xml:lang="nl">Booleaanse waarde van het attribuut</xs:documentation>
						<xs:documentation xml:lang="es">Valor booleano del atributo</xs:documentation>
						<xs:documentation xml:lang="it">Valore booleano dell'attributo</xs:documentation>
						<xs:documentation xml:lang="cs">Logická hodnota atributu</xs:documentation>
						<xs:documentation xml:lang="hu">Az attribútum logikai értéke</xs:documentation>
					</xs:annotation>
				</xs:element>
			</xs:choice>
		</xs:sequence>
	</xs:complexType>
	<xs:simpleType name="BicCodeType">
		<xs:annotation>
			<xs:documentation xml:lang="en">BIC Code (SWIFT)</xs:documentation>
			<xs:documentation xml:lang="de">BIC-Code (SWIFT)</xs:documentation>
			<xs:documentation xml:lang="fr">BIC Code (SWIFT)</xs:documentation>
			<xs:documentation xml:lang="nl">BIC Code (SWIFT)</xs:documentation>
			<xs:documentation xml:lang="es">Código BIC (SWIFT)</xs:documentation>
