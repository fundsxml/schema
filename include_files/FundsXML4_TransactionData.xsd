					<xs:documentation xml:lang="en">Date when earning has been booked into portfolio</xs:documentation>
					<xs:documentation xml:lang="de">Datum, an dem der Ertrag ins Portfolio gebucht wurde</xs:documentation>
					<xs:documentation xml:lang="fr">Date quand earning un been booked into portefeuille</xs:documentation>
					<xs:documentation xml:lang="nl">Datum wanneer earning heeft been booked into portefeuille</xs:documentation>
					<xs:documentation xml:lang="es">Fecha en que el rendimiento ha sido contabilizado en la cartera</xs:documentation>
					<xs:documentation xml:lang="it">Data in cui i guadagni sono stati contabilizzati nel portafoglio</xs:documentation>
					<xs:documentation xml:lang="cs">Datum, kdy byl výnos zaúčtován do portfolia</xs:documentation>
					<xs:documentation xml:lang="hu">A dátum, amikor a hozam a portfólióba könyvelésre került</xs:documentation>
					<xs:documentation xml:lang="da">Dato hvor afkastet blev bogført i porteføljen</xs:documentation>
					<xs:documentation xml:lang="pl">Data zaksięgowania dochodu w portfelu</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ValutaDate" type="xs:date" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Value date</xs:documentation>
					<xs:documentation xml:lang="de">Valutadatum</xs:documentation>
					<xs:documentation xml:lang="fr">Valeur date</xs:documentation>
					<xs:documentation xml:lang="nl">Waarde datum</xs:documentation>
					<xs:documentation xml:lang="es">Fecha valor</xs:documentation>
					<xs:documentation xml:lang="it">Data valuta</xs:documentation>
					<xs:documentation xml:lang="cs">Datum valuty</xs:documentation>
					<xs:documentation xml:lang="hu">Értéknap</xs:documentation>
					<xs:documentation xml:lang="da">Valørdato</xs:documentation>
					<xs:documentation xml:lang="pl">Data waluty (value date)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="EntryCurrency" type="ISOCurrencyCodeType">
				<xs:annotation>
					<xs:documentation xml:lang="en">Booking currency</xs:documentation>
					<xs:documentation xml:lang="de">Buchungswährung</xs:documentation>
					<xs:documentation xml:lang="fr">Booking devise</xs:documentation>
					<xs:documentation xml:lang="nl">Booking valuta</xs:documentation>
					<xs:documentation xml:lang="es">Moneda de contabilizaci\u00f3n</xs:documentation>
					<xs:documentation xml:lang="it">Valuta della prenotazione</xs:documentation>
					<xs:documentation xml:lang="cs">Účetní měna</xs:documentation>
					<xs:documentation xml:lang="hu">Konyveles penzneme</xs:documentation>
					<xs:documentation xml:lang="da">Bogføringsvaluta</xs:documentation>
					<xs:documentation xml:lang="pl">Waluta księgowania</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="IncomeCurrency" type="ISOCurrencyCodeType" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Income currency</xs:documentation>
					<xs:documentation xml:lang="de">Eträgniswährung</xs:documentation>
					<xs:documentation xml:lang="fr">Income devise</xs:documentation>
					<xs:documentation xml:lang="nl">Income valuta</xs:documentation>
					<xs:documentation xml:lang="es">Moneda de ingresos</xs:documentation>
					<xs:documentation xml:lang="it">Valuta di reddito</xs:documentation>
					<xs:documentation xml:lang="cs">Měna výnosů</xs:documentation>
					<xs:documentation xml:lang="hu">Bevetel penzneme</xs:documentation>
					<xs:documentation xml:lang="da">Indkomstvaluta</xs:documentation>
					<xs:documentation xml:lang="pl">Waluta dochodu</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="EntryValue" type="FundAmountType">
				<xs:annotation>
					<xs:documentation xml:lang="en">Booking value</xs:documentation>
					<xs:documentation xml:lang="de">Buchungsbetrag</xs:documentation>
					<xs:documentation xml:lang="fr">Booking valeur</xs:documentation>
					<xs:documentation xml:lang="nl">Booking waarde</xs:documentation>
					<xs:documentation xml:lang="es">Valor de contabilizaci\u00f3n</xs:documentation>
					<xs:documentation xml:lang="it">Valore della prenotazione</xs:documentation>
					<xs:documentation xml:lang="cs">Účetní hodnota</xs:documentation>
					<xs:documentation xml:lang="hu">Könyvelési érték</xs:documentation>
					<xs:documentation xml:lang="da">Bogføringsværdi</xs:documentation>
					<xs:documentation xml:lang="pl">Wartość księgowa</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Interests" type="FundAmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Interests value</xs:documentation>
					<xs:documentation xml:lang="de">Zinswert</xs:documentation>
					<xs:documentation xml:lang="fr">Interests valeur</xs:documentation>
					<xs:documentation xml:lang="nl">Interests waarde</xs:documentation>
					<xs:documentation xml:lang="es">Valor de intereses</xs:documentation>
