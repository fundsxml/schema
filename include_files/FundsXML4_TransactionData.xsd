<xs:schema xmlns:altova="http://www.altova.com/xml-schema-extensions" xmlns:vc="http://www.w3.org/2007/XMLSchema-versioning" xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" attributeFormDefault="unqualified" vc:minVersion="1.1">
	<xs:include schemaLocation="FundsXML4_Core.xsd"/>
	<xs:complexType name="EarningsType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Container type for multiple earnings (coupons, dividends, distributions) from security positions in a fund portfolio</xs:documentation>
			<xs:documentation xml:lang="de">Container-Typ für mehrere Erträge (Coupons, Dividenden, Ausschüttungen) aus Wertpapierpositionen in einem Fondsportfolio</xs:documentation>
			<xs:documentation xml:lang="fr">Type conteneur pour plusieurs earnings (coupons, dividendes, distributions) des positions de titres dans un portefeuille de fonds</xs:documentation>
			<xs:documentation xml:lang="nl">Container type voor meerdere earnings (coupons, dividenden, uitkeringen) van effectenposities in een fondsportefeuille</xs:documentation>
			<xs:documentation xml:lang="es">Tipo contenedor para m\u00faltiples rendimientos (cupones, dividendos, distribuciones) de posiciones de valores en una cartera de fondos</xs:documentation>
			<xs:documentation xml:lang="it">Tipo di contenitore per guadagni multipli (cedole, dividendi, distribuzioni) da posizioni di titoli in un portafoglio di fondi</xs:documentation>
			<xs:documentation xml:lang="cs">Typ kontejneru pro více výnosů (kupóny, dividendy, distribuce) z pozic cenných papírů v portfoliu fondu</xs:documentation>
			<xs:documentation xml:lang="hu">Tároló típus több hozamhoz (kuponok, osztalékok, szétosztások) az értékpapír pozíciókból egy alap portfólióban</xs:documentation>
			<xs:documentation xml:lang="da">Containertype til flere indtjeninger (kuponer, udbytter, udlodninger) fra værdipapirpositioner i en fondsportefølje</xs:documentation>
			<xs:documentation xml:lang="pl">Typ kontenera dla wielu dochodów (kupony, dywidendy, dystrybucje) z pozycji papierów wartościowych w portfelu funduszu</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Earning" type="EarningType" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation xml:lang="en">Earning data (single coupon, dividend or distribution) resulting from a security position</xs:documentation>
					<xs:documentation xml:lang="de">Ertragsdaten (einzelner Coupon, Dividende oder Ausschüttung) aus einer Wertpapierposition</xs:documentation>
					<xs:documentation xml:lang="fr">Earning données (unique coupon, dividende ou distribution) resulting de un titre position</xs:documentation>
					<xs:documentation xml:lang="nl">Earning gegevens (enkel coupon, dividend van uitkering) resulting van een effect positie</xs:documentation>
					<xs:documentation xml:lang="es">Datos de rendimiento (cup\u00f3n individual, dividendo o distribuci\u00f3n) resultante de una posici\u00f3n de valores</xs:documentation>
					<xs:documentation xml:lang="it">Dati sui guadagni (cedola unica, dividendo o distribuzione) derivanti da una posizione in titoli</xs:documentation>
					<xs:documentation xml:lang="cs">Údaje o výnosu (jednotlivý kupón, dividenda nebo distribuce) plynoucím z pozice v cenném papíru</xs:documentation>
					<xs:documentation xml:lang="hu">Hozam adat (egyedi kupon, osztalék vagy szétosztási) egy értékpapír pozícióból</xs:documentation>
					<xs:documentation xml:lang="da">Earning-data (enkelt kupon, udbytte eller udlodning) hidrørende fra en værdipapirposition</xs:documentation>
					<xs:documentation xml:lang="pl">Dane dochodu (pojedynczy kupon, dywidenda lub wypłata) wynikające z pozycji w papierze wartościowym</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="EarningType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Single earning record containing coupon, dividend or distribution data from a security position including amounts, dates, tax information and booking details</xs:documentation>
			<xs:documentation xml:lang="de">Einzelner Ertragsdatensatz mit Coupon-, Dividenden- oder Ausschüttungsdaten aus einer Wertpapierposition einschließlich Beträge, Daten, Steuerinformationen und Buchungsdetails</xs:documentation>
			<xs:documentation xml:lang="fr">Enregistrement earning unique contenant les données de coupon, dividende ou distribution d'une position de titre incluant montants, dates, informations fiscales et détails de comptabilisation</xs:documentation>
			<xs:documentation xml:lang="nl">Enkele opbrengstrecord met coupon-, dividend- of uitkeringsgegevens van een effectenpositie, inclusief bedragen, data, fiscale informatie en boekingsdetails</xs:documentation>
			<xs:documentation xml:lang="es">Registro de rendimiento individual que contiene datos de cup\u00f3n, dividendo o distribuci\u00f3n de una posici\u00f3n de valores incluyendo importes, fechas, informaci\u00f3n fiscal y detalles de contabilizaci\u00f3n</xs:documentation>
			<xs:documentation xml:lang="it">Record di guadagno singolo contenente dati su cedole, dividendi o distribuzione da una posizione di titolo, inclusi importi, date, informazioni fiscali e dettagli di prenotazione</xs:documentation>
			<xs:documentation xml:lang="cs">Jednotlivý záznam výnosu obsahující údaje o kupónu, dividendě nebo distribuci z pozice cenného papíru včetně částek, dat, daňových informací a účetních detailů</xs:documentation>
			<xs:documentation xml:lang="hu">Egyedi hozam rekord kupon, osztalék vagy szétosztási adatokkal egy értékpapír pozícióból, beleértve az összegeket, dátumokat, adó információkat és könyvelési részleteket</xs:documentation>
			<xs:documentation xml:lang="da">Enkelt indtægtspost med kupon-, udbytte- eller udlodningsdata fra en værdipapirposition, herunder beløb, datoer, skatteoplysninger og bogføringsdetaljer</xs:documentation>
			<xs:documentation xml:lang="pl">Pojedynczy rekord przychodu zawierający dane o kuponie, dywidendzie lub dystrybucji z pozycji papieru wartościowego, w tym kwoty, daty, informacje podatkowe i szczegóły księgowania</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="EarningID" type="Text256Type">
				<xs:annotation>
					<xs:documentation xml:lang="en">Unique Earning ID</xs:documentation>
					<xs:documentation xml:lang="de">Eindeutige Transaktionsnummer (Auftragsnummer)</xs:documentation>
					<xs:documentation xml:lang="fr">Identifiant unique de revenu (Earning ID)</xs:documentation>
					<xs:documentation xml:lang="nl">Uniek Earning ID</xs:documentation>
					<xs:documentation xml:lang="es">ID de rendimiento \u00fanico</xs:documentation>
					<xs:documentation xml:lang="it">ID guadagno univoco</xs:documentation>
					<xs:documentation xml:lang="cs">Jedinečné ID výnosu (Earning ID)</xs:documentation>
					<xs:documentation xml:lang="hu">Egyedi hozam azonosító</xs:documentation>
					<xs:documentation xml:lang="da">Unikt Earning-ID</xs:documentation>
					<xs:documentation xml:lang="pl">Unikalny identyfikator dochodu (Earning ID)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CancellationFlag" type="xs:boolean" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Indicates whether earning has been cancelled</xs:documentation>
					<xs:documentation xml:lang="de">Kennzeichen ob das Erträgnis storniert wurde</xs:documentation>
					<xs:documentation xml:lang="fr">Indique si le revenu a été annulé</xs:documentation>
					<xs:documentation xml:lang="nl">Geeft aan of de earning is geannuleerd</xs:documentation>
					<xs:documentation xml:lang="es">Indica si el rendimiento ha sido cancelado</xs:documentation>
					<xs:documentation xml:lang="it">Indica se l'accumulo è stato annullato</xs:documentation>
					<xs:documentation xml:lang="cs">Označuje, zda earning has been cancelled</xs:documentation>
					<xs:documentation xml:lang="hu">Jelzi, hogy a hozam visszavonasra kerult-e</xs:documentation>
					<xs:documentation xml:lang="da">Angiver, om indtjeningen er annulleret</xs:documentation>
					<xs:documentation xml:lang="pl">Wskazuje, czy dochód został anulowany</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="OriginalEarningID" type="Text256Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Earning ID of cancelled earning</xs:documentation>
					<xs:documentation xml:lang="de">Ertrags-ID des stornierten Ertrages</xs:documentation>
					<xs:documentation xml:lang="fr">Earning ID de cancelled earning</xs:documentation>
					<xs:documentation xml:lang="nl">Earning ID van cancelled earning</xs:documentation>
					<xs:documentation xml:lang="es">ID de rendimiento del rendimiento cancelado</xs:documentation>
					<xs:documentation xml:lang="it">ID guadagno del guadagno annullato</xs:documentation>
					<xs:documentation xml:lang="cs">ID výnosu stornovaného výnosu</xs:documentation>
					<xs:documentation xml:lang="hu">A visszavont hozam azonosítója</xs:documentation>
					<xs:documentation xml:lang="da">Earning-ID for annulleret earning</xs:documentation>
					<xs:documentation xml:lang="pl">Identyfikator dochodu anulowanego dochodu</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AssetUniqueID" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Unique ID of asset (link to AssetMasterData)</xs:documentation>
					<xs:documentation xml:lang="de">Referenz zu den Wertpapierstammdaten</xs:documentation>
					<xs:documentation xml:lang="fr">Unique ID de actif (link à AssetMasterData)</xs:documentation>
					<xs:documentation xml:lang="nl">Uniek ID van actief (link naar AssetMasterData)</xs:documentation>
					<xs:documentation xml:lang="es">ID \u00fanico de activo (enlace a AssetMasterData)</xs:documentation>
					<xs:documentation xml:lang="it">ID univoco dell'asset (link a AssetMasterData)</xs:documentation>
					<xs:documentation xml:lang="cs">Jedinečné ID aktiva (odkaz na AssetMasterData)</xs:documentation>
					<xs:documentation xml:lang="hu">Az eszköz egyedi azonosítója (hivatkozás az AssetMasterData-ra)</xs:documentation>
					<xs:documentation xml:lang="da">Unikt ID for aktiv (link til AssetMasterData)</xs:documentation>
					<xs:documentation xml:lang="pl">Unikalny identyfikator aktywa (powiązanie z AssetMasterData)</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:IDREF">
						<xs:maxLength value="256"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="Identifiers" type="IdentifiersType" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Identifiers of instrument (like ISIN, Ticker, ...)</xs:documentation>
					<xs:documentation xml:lang="de">Kennnummern des Instrumentes (ISIN, Ticker, ...)</xs:documentation>
					<xs:documentation xml:lang="fr">Identifiers de instrument (like ISIN, Ticker, ...)</xs:documentation>
					<xs:documentation xml:lang="nl">Identifiers van instrument (like ISIN, Ticker, ...)</xs:documentation>
					<xs:documentation xml:lang="es">Identificadores del instrumento (como ISIN, Ticker, ...)</xs:documentation>
					<xs:documentation xml:lang="it">Identificatori dello strumento (come ISIN, Ticker, ...)</xs:documentation>
					<xs:documentation xml:lang="cs">Identifikátory nástroje (např. ISIN, Ticker, ...)</xs:documentation>
					<xs:documentation xml:lang="hu">Az instrumentum azonosítói (pl. ISIN, Ticker, ...)</xs:documentation>
					<xs:documentation xml:lang="da">Instrumentets identifikatorer (såsom ISIN, Ticker, ...)</xs:documentation>
					<xs:documentation xml:lang="pl">Identyfikatory instrumentu (np. ISIN, Ticker, ...)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="EarningKind">
				<xs:annotation>
					<xs:documentation xml:lang="en">Type of earning:
Coupon, Dividend, Fund distribution, ...</xs:documentation>
					<xs:documentation xml:lang="de">Diese Bezeichnung ist aus dem Dictionary zu entnehmen.Gibt die Ertragsart an: z.B Coupon, Dividend,Fund distribution</xs:documentation>
					<xs:documentation xml:lang="fr">Type de earning:
Coupon, Dividende, Fonds distribution, ...</xs:documentation>
					<xs:documentation xml:lang="nl">Type van earning:
Coupon, Dividend, Fonds uitkering, ...</xs:documentation>
					<xs:documentation xml:lang="es">Tipo de rendimiento:
Cup\u00f3n, Dividendo, Distribuci\u00f3n de fondo, ...</xs:documentation>
					<xs:documentation xml:lang="it">Tipo di guadagno:
Cedole, dividendi, distribuzione di fondi, ...</xs:documentation>
					<xs:documentation xml:lang="cs">Typ výnosu:
Kupón, Dividenda, Distribuce fondu, ...</xs:documentation>
					<xs:documentation xml:lang="hu">A hozam típusa:
Kupon, Osztalék, Alapból származó kifizetés, ...</xs:documentation>
					<xs:documentation xml:lang="da">Type af indtjening:
Kupon, udbytte, fondsudlodning, ...</xs:documentation>
					<xs:documentation xml:lang="pl">Typ dochodu:
Kupon, Dywidenda, Wypłata z funduszu, ...</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Coupon"/>
						<xs:enumeration value="Dividend"/>
						<xs:enumeration value="Fund distribution"/>
						<xs:enumeration value="Interest deposit/giro"/>
						<xs:enumeration value="Interest swap"/>
						<xs:enumeration value="Other"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="ClosingDate" type="xs:date" minOccurs="0">
				<xs:annotation>
					<xs:documentation xml:lang="en">Closing date / trade date</xs:documentation>
					<xs:documentation xml:lang="de">Datum, an dem das Geschaeft abgeschlossen wurde</xs:documentation>
					<xs:documentation xml:lang="fr">Date de clôture / date de négociation</xs:documentation>
					<xs:documentation xml:lang="nl">Closing datum / trade datum</xs:documentation>
					<xs:documentation xml:lang="es">Fecha de cierre / fecha de operaci\u00f3n</xs:documentation>
					<xs:documentation xml:lang="it">Data di chiusura/data di negoziazione</xs:documentation>
					<xs:documentation xml:lang="cs">Datum uzavření / datum obchodu</xs:documentation>
					<xs:documentation xml:lang="hu">Záró dátum / kereskedési dátum</xs:documentation>
					<xs:documentation xml:lang="da">Lukningsdato / handelsdato</xs:documentation>
					<xs:documentation xml:lang="pl">Data zamknięcia / data zawarcia transakcji</xs:documentation>
				</xs:annotation>
			</xs:element>
