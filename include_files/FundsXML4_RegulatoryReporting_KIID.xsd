                           	   <xs:documentation xml:lang="en">Name of the share class</xs:documentation>
                           	   <xs:documentation xml:lang="de">Name der Anteilsklasse</xs:documentation>
                           	   <xs:documentation xml:lang="fr">Nom de la classe de parts</xs:documentation>
                           	   <xs:documentation xml:lang="nl">Naam van de aandelenklasse</xs:documentation>
