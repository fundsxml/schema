   <xs:simpleType name="CICCodeType">
      <xs:annotation>
         <xs:documentation xml:lang="en">CIC code (4 positions) to identify a kind of security</xs:documentation>
         <xs:documentation xml:lang="de">CIC-Code (4 Stellen) zur Identifikation der Art des Wertpapiers</xs:documentation>
         <xs:documentation xml:lang="fr">CIC code (4 positions) à identify un kind de titre</xs:documentation>
         <xs:documentation xml:lang="nl">CIC code (4 positions) naar identify een kind van effect</xs:documentation>
         <xs:documentation xml:lang="es">CIC codigo (4 positions) a identify un kind de effect</xs:documentation>
         <xs:documentation xml:lang="it">Codice CIC (4 posizioni) per identificare un tipo di titolo</xs:documentation>
         <xs:documentation xml:lang="cs">Kód CIC (4 pozice) pro identifikaci druhu cenného papíru</xs:documentation>
         <xs:documentation xml:lang="hu">CIC kód (4 pozíció) egy értékpapírfajta azonosítására</xs:documentation>
         <xs:documentation xml:lang="da">CIC-kode (4 positioner) til at identificere en type værdipapir</xs:documentation>
         <xs:documentation xml:lang="pl">Kod CIC (4 pozycje) identyfikujący rodzaj papieru wartościowego</xs:documentation>
         <xs:documentation xml:lang="sv">CIC-kod (4 positioner) för att identifiera en typ av värdepapper</xs:documentation>
      </xs:annotation>
      <xs:restriction base="xs:string">
         <xs:minLength value="4"/>
         <xs:maxLength value="4"/>
         <xs:pattern value="([A-Z]{2}([A-F]|[0-9]){1}[1-9]{1})"/>
      </xs:restriction>
   </xs:simpleType>
